{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/exchangeYouTubeCode",
        "function": "exchangeYouTubeCode"
      },
      {
        "source": "/api/youtubeAccessToken",
        "function": "youtubeAccessToken"
      },
      {
        "source": "/api/revokeYouTubeSession",
        "function": "revokeYouTubeSession"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "target": "focustube"
  }
}
